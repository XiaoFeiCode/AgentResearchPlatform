# ============================================================
# 多源舆情智能分析系统
# 环境变量示例文件
#
# 使用方式：
#   1. 复制本文件并重命名为 `.env`
#   2. 将所有 `your_*` 占位符替换成你自己的真实配置
#   3. 不要把真实 `.env` 提交到 GitHub
# ============================================================


# ====================== 服务配置 ======================
# 本地 FastAPI 后端服务地址和端口。
HOST=0.0.0.0
PORT=5000
LOG_LEVEL=INFO

# Docker Compose 暴露到宿主机的前端端口。
FRONTEND_PORT=80


# ====================== 数据库配置 ======================
# 本地开发一般使用 127.0.0.1:3306。
# Docker Compose 内部运行时，后端会连接 MySQL 服务名 `db`。
DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=media_crawler
DB_CHARSET=utf8mb4

# Docker MySQL 映射到宿主机的端口。
# 如果你本机 MySQL 已经占用 3306，可以使用 3307。
DB_EXPOSE_PORT=3307


# ====================== 大模型配置 ======================
# 各 Agent 使用 OpenAI 兼容格式的 Chat Completions 接口。
# 可以所有 Agent 共用同一个平台和密钥，也可以分别配置不同平台。

# Insight Agent：负责本地/私域数据库挖掘。
INSIGHT_ENGINE_API_KEY=your_insight_engine_api_key
INSIGHT_ENGINE_BASE_URL=https://api.deepseek.com
INSIGHT_ENGINE_MODEL_NAME=deepseek-v4-pro

# Media Agent：负责媒体报道和公开网络搜索。
MEDIA_ENGINE_API_KEY=your_media_engine_api_key
MEDIA_ENGINE_BASE_URL=https://api.deepseek.com
MEDIA_ENGINE_MODEL_NAME=deepseek-v4-pro

# Query Agent：负责权威信息检索和事实核查。
QUERY_ENGINE_API_KEY=your_query_engine_api_key
QUERY_ENGINE_BASE_URL=https://api.deepseek.com
QUERY_ENGINE_MODEL_NAME=deepseek-v4-pro

# Report Agent：负责最终报告生成和渲染辅助。
REPORT_ENGINE_API_KEY=your_report_engine_api_key
REPORT_ENGINE_BASE_URL=https://api.deepseek.com
REPORT_ENGINE_MODEL_NAME=deepseek-v4-pro

# Forum Host：负责协调多 Agent 讨论。
FORUM_HOST_API_KEY=your_forum_host_api_key
FORUM_HOST_BASE_URL=https://api.deepseek.com
FORUM_HOST_MODEL_NAME=deepseek-v4-pro

# Keyword Optimizer：负责优化数据库搜索关键词。
KEYWORD_OPTIMIZER_API_KEY=your_keyword_optimizer_api_key
KEYWORD_OPTIMIZER_BASE_URL=https://api.deepseek.com
KEYWORD_OPTIMIZER_MODEL_NAME=deepseek-v4-pro

# SentinelSpider Agent：爬虫侧可选的大模型配置。
SENTINEL_SPIDER_API_KEY=your_sentinel_spider_api_key
SENTINEL_SPIDER_BASE_URL=https://api.deepseek.com
SENTINEL_SPIDER_MODEL_NAME=deepseek-v4-pro


# ====================== 搜索工具配置 ======================
# 支持值：TavilyAPI、BochaAPI、AnspireAPI
SEARCH_TOOL_TYPE=TavilyAPI

# Tavily API 密钥，SEARCH_TOOL_TYPE=TavilyAPI 时需要配置。
TAVILY_API_KEY=your_tavily_api_key

# Bocha 搜索配置，SEARCH_TOOL_TYPE=BochaAPI 时需要配置。
BOCHA_BASE_URL=https://api.bocha.cn/v1/ai-search
BOCHA_WEB_SEARCH_API_KEY=your_bocha_api_key
BOCHA_API_KEY=your_bocha_api_key

# Anspire 搜索配置，SEARCH_TOOL_TYPE=AnspireAPI 时需要配置。
ANSPIRE_BASE_URL=https://plugin.anspire.cn/api/ntsearch/search
ANSPIRE_API_KEY=your_anspire_api_key


# ====================== Insight 搜索与分析配置 ======================
ENABLE_CLUSTERING=true
MAX_CLUSTERED_RESULTS=50
RESULTS_PER_CLUSTER=5

# 情感分析是可选功能。
# 只有在 transformers/torch 已安装且模型能正常加载后，再改成 true。
SENTIMENT_ANALYSIS_ENABLED=false
ENABLE_SENTIMENT_PER_SEARCH=false

# HuggingFace 模型名或本地模型路径。
# 如果要离线稳定运行，建议提前下载模型，并改成本地路径。
SENTIMENT_MODEL_NAME=tabularisai/multilingual-sentiment-analysis
CLUSTERING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

DEFAULT_SEARCH_HOT_CONTENT_LIMIT=100
DEFAULT_SEARCH_TOPIC_GLOBALLY_LIMIT_PER_TABLE=50
DEFAULT_SEARCH_TOPIC_BY_DATE_LIMIT_PER_TABLE=100
DEFAULT_GET_COMMENTS_FOR_TOPIC_LIMIT=500
DEFAULT_SEARCH_TOPIC_ON_PLATFORM_LIMIT=200

MAX_SEARCH_RESULTS_FOR_LLM=0
MAX_HIGH_CONFIDENCE_SENTIMENT_RESULTS=0
MAX_REFLECTIONS=3
MAX_PARAGRAPHS=6
SEARCH_TIMEOUT=240
MAX_CONTENT_LENGTH=500000
SEARCH_CONTENT_MAX_LENGTH=500000
SAVE_INTERMEDIATE_STATES=true
MAX_SEARCH_RESULTS=20
